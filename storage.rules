rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isImageUpload(maxSizeMB) {
      return request.resource != null
        && request.resource.size < maxSizeMB * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    function isHeroMediaUpload(maxSizeMB) {
      return request.resource != null
        && request.resource.size < maxSizeMB * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*') ||
          request.resource.contentType.matches('video/.*')
        );
    }

    // ---------- Site Content CMS ----------
    match /site-content/{allPaths=**} {
      allow read: if true;
      allow create, update: if isSignedIn() && isImageUpload(5);
      allow delete: if isSignedIn();
    }

    // ---------- Homepage Hero Media ----------
    match /site/home-hero/{allPaths=**} {
      allow read: if true;
      allow create, update: if isSignedIn() && isHeroMediaUpload(50);
      allow delete: if isSignedIn();
    }

    // ---------- Avatar files ----------
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if isSelf(userId) && isImageUpload(5);
      allow delete: if isSelf(userId);
    }

    // ---------- Profile cover and other user-owned files ----------
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if isSelf(userId) && isImageUpload(5);
      allow delete: if isSelf(userId);
    }

    // ---------- Post images ----------
    match /posts/{userId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if isSelf(userId) && isImageUpload(10);
      allow delete: if isSelf(userId);
    }

    // ---------- Product images ----------
    match /products/{userId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if isSelf(userId) && isImageUpload(10);
      allow delete: if isSelf(userId);
    }

    // ---------- Communication request uploads ----------
    match /uploads/{uid}/{allPaths=**} {
      allow read: if isSignedIn();
      allow create, update: if isSelf(uid) && isImageUpload(10);
      allow delete: if isSelf(uid);
    }

    // ---------- Default deny ----------
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
