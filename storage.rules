rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isImageUpload(maxSizeMB) {
      return request.resource != null
        && request.resource.size < maxSizeMB * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Avatar files: avatars/{userId}/...
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if isSelf(userId) && isImageUpload(5);
      allow delete: if isSelf(userId);
    }

    // Profile cover and other user-owned files: users/{userId}/...
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if isSelf(userId) && isImageUpload(5);
      allow delete: if isSelf(userId);
    }

    // Post images: posts/{userId}/...
    match /posts/{userId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if isSelf(userId) && isImageUpload(10);
      allow delete: if isSelf(userId);
    }

    // Product images: products/{userId}/...
    match /products/{userId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if isSelf(userId) && isImageUpload(10);
      allow delete: if isSelf(userId);
    }

    // Communication request uploads
    match /uploads/{uid}/{allPaths=**} {
      allow read: if isSignedIn();
      allow create, update: if isSelf(uid) && isImageUpload(10);
      allow delete: if isSelf(uid);
    }

    // Deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
