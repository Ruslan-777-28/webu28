rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function hasClaim(claim) {
      return isSignedIn() && request.auth.token[claim] == true;
    }

    function isAdmin() {
      return hasClaim('admin');
    }

    function isEditor() {
      return isAdmin() || hasClaim('editor');
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    
    // ---------- Rules ----------
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSelf(userId) || isAdmin();
    }

    match /posts/{path=**} {
      allow read: if true;
      allow write: if isEditor();
    }

    match /products/{path=**} {
      allow read: if true;
      allow write: if isEditor();
    }

    match /users/{path=**} {
      allow read: if isSignedIn();
      allow write: if isEditor();
    }

    // Deny all other routes
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
