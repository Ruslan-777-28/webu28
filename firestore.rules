
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    
    // Claim-based helpers
    function hasClaim(claim) {
      return isSignedIn() && request.auth.token[claim] == true;
    }

    function isAdmin() {
      return hasClaim('admin');
    }

    function isEditor() {
      return isAdmin() || hasClaim('editor');
    }
    
    function isAuthor() {
      return isEditor() || hasClaim('author');
    }

    function isModerator() {
      return isAdmin() || hasClaim('moderator');
    }
    
    // ---------- Users ----------
    match /users/{uid} {
      allow get, list: if isSignedIn();
      allow create: if isSelf(uid);
      // Only Admin can change roles. Others can update their own profile.
      allow update: if (isSelf(uid) && request.resource.data.roles == resource.data.roles) || isAdmin();
      allow delete: if isAdmin();
    }

    // ---------- Posts (Blog and other types) ----------
    match /posts/{postId} {
        // Public can read published blog posts, and any non-blog posts (maintaining original open access for them)
        allow get: if (resource.data.contentType == 'blog' && resource.data.status == 'published')
                    || (resource.data.get('contentType', 'blog') != 'blog');
        
        allow list: if true; 

        // Staff can read any post for the admin panel. Public can read published.
        allow read: if isAuthor() || (resource.data.contentType == 'blog' && resource.data.status == 'published');
        
        // Authors can create posts
        allow create: if isAuthor() && request.resource.data.authorId == request.auth.uid;

        // Authors can update their own posts. Editors/Admins can update any post.
        allow update: if (isAuthor() && resource.data.authorId == request.auth.uid) || isEditor();

        // Editors/Admins can delete posts.
        allow delete: if isEditor();

        // Comments subcollection
        match /comments/{commentId} {
            allow read: if true;
            allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
            allow update: if false;
            allow delete: if isSignedIn() && (resource.data.uid == request.auth.uid || isModerator());
        }
    }

    // ---------- Products ----------
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isEditor();
    }

    // ---------- Config Collections ----------
    match /blogSettings/{docId} {
      allow read: if true;
      allow write: if isEditor();
    }

    match /siteSettings/{docId} {
      allow read: if true;
      allow write: if isEditor();
    }

    match /sitePages/{docId} {
        allow read: if true;
        allow write: if isEditor();
    }

    // ---------- Other App-Specific Collections (from original rules) ----------
    match /notifications/{notificationId} {
      allow read: if isSelf(resource.data.uid);
      allow write: if false;
    }

    match /walletLedger/{txId} {
      allow get, list: if isSelf(resource.data.uid);
      allow write: if false;
    }

    match /walletHolds/{holdId} {
      allow read: if isSelf(resource.data.uid);
      allow write: if false;
    }

    match /communicationOffers/{offerId} {
      allow get, list: if isSignedIn();
      allow create: if isSelf(request.resource.data.ownerId);
      allow update, delete: if isSelf(resource.data.authorId);
    }

    match /communicationRequests/{requestId} {
      function isParticipant() {
        return isSignedIn() && (
          isSelf(resource.data.initiatorId) || 
          isSelf(resource.data.authorId)
        );
      }
      allow read: if isParticipant();
      allow write: if false;

      match /messages/{messageId} {
        allow read: if isParticipant();
        allow write: if false;
      }
    }

    match /favorites/{favoriteId} {
      allow read: if isSignedIn();
      allow create: if isSelf(request.resource.data.uid);
      allow delete: if isSelf(resource.data.uid);
      allow update: if false;
    }

    match /likes/{likeId} {
      allow read: if isSignedIn();
      allow create: if isSelf(request.resource.data.uid);
      allow delete: if isSelf(resource.data.uid);
      allow update: if false;
    }

    match /calls/{callId} {
      function isCallParticipant() {
        return isSignedIn() && (
          isSelf(resource.data.callerId) || 
          isSelf(resource.data.receiverId)
        );
      }
      allow read: if isCallParticipant();
      allow write: if false;
    }

    match /callTranslations/{callId} {
      allow read, write: if isSignedIn();
      match /segments/{segmentId} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
