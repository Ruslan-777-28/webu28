rules_version = '2';

// ############################################################################
// # MASTER SOURCE OF TRUTH: LECTOR (Website Repo)
// # --------------------------------------------------------------------------
// # This file is the CANONICAL home for shared Firestore security rules.
// # It covers both LECTOR (Site) and ConnectU (App) platforms.
// #
// # RULES MUST BE DEPLOYED EXCLUSIVELY FROM THIS REPOSITORY.
// # DO NOT DEPLOY RULES FROM THE APP REPO (ConnectU) AS IT WILL OVERWRITE 
// # CRITICAL PUBLIC CMS ACCESS RULES.
// ############################################################################

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ---------- Users ----------
    match /users/{uid} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSelf(uid);
      allow update: if isSelf(uid);
      allow delete: if false;
    }

    // ---------- Products ----------
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    // ---------- Notifications ----------
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create, update, delete: if false;
    }
    
    // ---------- Referrals ----------
    match /referrals/{referredUid} {
      allow read: if isSignedIn() && (request.auth.uid == referredUid || resource.data.referrerUid == request.auth.uid);
      allow write: if false; // Only server-side creation
    }

    // ---------- Bonus Ledger ----------
    match /bonusLedger/{txId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow write: if false; // Server-only
    }

    // ---------- Wallet Ledger ----------
    match /walletLedger/{txId} {
      allow get, list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create, update, delete: if false;
    }

    // ---------- Wallet Holds ----------
    match /walletHolds/{holdId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create, update, delete: if false;
    }

    // ---------- Communication Offers ----------
    match /communicationOffers/{offerId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    // ---------- Communication Requests & Messages ----------
    match /communicationRequests/{requestId} {
      function isParticipant() {
        return isSignedIn() && (
          resource.data.initiatorId == request.auth.uid ||
          resource.data.authorId == request.auth.uid
        );
      }

      allow read: if isParticipant();
      allow create, update, delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/communicationRequests/$(requestId)).data.initiatorId == request.auth.uid ||
          get(/databases/$(database)/documents/communicationRequests/$(requestId)).data.authorId == request.auth.uid
        );
        allow create, update, delete: if false;
      }
    }

    // ---------- Posts ----------
    match /posts/{postId} {
      allow get, list: if true;

      // Authors can create posts but cannot self-assign staff-only privileges.
      // Admin SDK (server-side) bypasses these rules for editorial operations.
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.sitePublished == false
        && request.resource.data.get('featured', false) == false
        && request.resource.data.get('pinned', false) == false
        && request.resource.data.get('editorialStatus', 'draft') in ['draft', 'submitted'];

      // Authors can update own posts but cannot modify staff-controlled fields.
      allow update: if isSignedIn()
        && resource.data.authorId == request.auth.uid
        && request.resource.data.authorId == resource.data.authorId
        && request.resource.data.get('sitePublished', false) == resource.data.get('sitePublished', false)
        && request.resource.data.get('featured', false) == resource.data.get('featured', false)
        && request.resource.data.get('pinned', false) == resource.data.get('pinned', false);

      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
        allow update: if false;
        allow delete: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      }
    }

    // ---------- Favorites ----------
    match /favorites/{favoriteId} {
      allow read: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ---------- Likes ----------
    match /likes/{likeId} {
      allow read: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ---------- Calls & Translations ----------
    match /calls/{callId} {
      function isCallParticipant() {
        return isSignedIn() && (
          resource.data.callerId == request.auth.uid ||
          resource.data.receiverId == request.auth.uid
        );
      }
      allow read: if isCallParticipant();
      allow create, update, delete: if false;
    }

    match /callTranslations/{callId} {
      allow read, write: if isSignedIn();

      match /segments/{segmentId} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }

    // ---------- Blog Settings ----------
    match /blogSettings/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ---------- Site Pages CMS ----------
    match /sitePages/{pageId} {
      allow read: if true;
      allow write: if isSignedIn();

      match /contentBlocks/{blockId} {
        allow read: if true;
        allow write: if isSignedIn();

        match /items/{itemId} {
          allow read: if true;
          allow write: if isSignedIn();
        }
      }
    }

    // ---------- FAQ Items ----------
    match /faqItems/{faqId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ---------- Homepage Hero Media ----------
    match /siteSettings/homeHeroMedia {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }

    // ---------- Site Settings ----------
    match /siteSettings/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ---------- Site Info Pages ----------
    match /siteInfoPages/{pageId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ---------- Friendships ----------
    match /friendships/{friendshipId} {
      allow read, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if false;
    }

    // ---------- Shares ----------
    match /shares/{shareId} {
      allow read: if isSignedIn() && (resource.data.senderUid == request.auth.uid || resource.data.targetUid == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.senderUid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.targetUid == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if false;
    }

    // ---------- Architect Council (Governance) ----------
    // Access is managed strictly through server-side API routes (/api/architect-council).
    // API uses Admin SDK to verify council eligibility and membership.
    // Direct client access is locked to admin only.
    match /architectCouncilThreads/{threadId} {
      allow read, write: if isSignedIn() && request.auth.token.admin == true;
      
      match /comments/{commentId} {
        allow read, write: if isSignedIn() && request.auth.token.admin == true;
      }
    }
    
    match /architectCouncilVotes/{voteId} {
      allow read, write: if isSignedIn() && request.auth.token.admin == true;
    }
    
    match /architectCouncilMembers/{uid} {
      allow read, write: if isSignedIn() && request.auth.token.admin == true;
    }

    // ---------- Community Architect Assignments ----------
    // Public reads go through server-side API (/api/community-architects)
    // which uses Admin SDK and strips notesInternal + admin-only fields.
    // Direct client reads: admin-only (for admin management pages).
    match /communityArchitectAssignments/{assignmentId} {
      allow read: if isSignedIn() && request.auth.token.admin == true;
      allow create, update, delete: if isSignedIn() && request.auth.token.admin == true;
    }

    // ---------- Contact Submissions ----------
    match /contactSubmissions/{submissionId} {
      allow create: if true;
      allow read: if isSignedIn() && request.auth.token.admin == true;
      allow update, delete: if isSignedIn() && request.auth.token.admin == true;
    }

    // ---------- Default deny ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
