
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function isAdmin() {
      // check for role field to avoid errors on documents without it
      return isSignedIn() && 'role' in getUserData(request.auth.uid) && getUserData(request.auth.uid).role == 'admin';
    }

    function isEditor() {
      return isSignedIn() && 'role' in getUserData(request.auth.uid) && (getUserData(request.auth.uid).role == 'editor' || isAdmin());
    }

    function isAuthor() {
      return isSignedIn() && 'role' in getUserData(request.auth.uid) && (getUserData(request.auth.uid).role == 'author' || isEditor());
    }

    // ---------- Users ----------
    match /users/{uid} {
      allow get, list: if isSignedIn();
      allow create: if isSelf(uid);
      // User can update their own profile, but not their role. Admin can update anything.
      allow update: if (isSelf(uid) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if false;
    }

    // ---------- Products ----------
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    // ---------- Notifications ----------
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create, update, delete: if false;
    }

    // ---------- Wallet Ledger ----------
    match /walletLedger/{txId} {
      allow get, list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create, update, delete: if false;
    }

    // ---------- Wallet Holds ----------
    match /walletHolds/{holdId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create, update, delete: if false;
    }

    // ---------- Communication Offers ----------
    match /communicationOffers/{offerId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    // ---------- Communication Requests & Messages ----------
    match /communicationRequests/{requestId} {
      function isParticipant() {
        return isSignedIn() && (
          resource.data.initiatorId == request.auth.uid || 
          resource.data.authorId == request.auth.uid
        );
      }
      
      allow read: if isParticipant();
      allow create, update, delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/communicationRequests/$(requestId)).data.initiatorId == request.auth.uid || 
          get(/databases/$(database)/documents/communicationRequests/$(requestId)).data.authorId == request.auth.uid
        );
        allow create, update, delete: if false;
      }
    }

    // ---------- Posts ----------
    match /posts/{postId} {
      allow get, list: if true;

      function isPostAuthor() {
        return isSignedIn() && resource.data.authorId == request.auth.uid;
      }

      function isNewPostAuthor() {
        return isSignedIn() && request.resource.data.authorId == request.auth.uid;
      }

      allow create: if isNewPostAuthor() && (request.resource.data.contentType != 'blog' || isAuthor());
      allow update, delete: if isPostAuthor() || (resource.data.contentType == 'blog' && isEditor());

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
        allow update: if false;
        allow delete: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      }
    }

    // ---------- Favorites ----------
    match /favorites/{favoriteId} {
      allow read: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ---------- Likes ----------
    match /likes/{likeId} {
      allow read: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ---------- Calls & Translations ----------
    match /calls/{callId} {
      function isCallParticipant() {
        return isSignedIn() && (
          resource.data.callerId == request.auth.uid || 
          resource.data.receiverId == request.auth.uid
        );
      }
      allow read: if isCallParticipant();
      allow create, update, delete: if false;
    }

    match /callTranslations/{callId} {
      // Тимчасово дозволяємо доступ для всіх автентифікованих користувачів для тестування Batch 3.2
      allow read, write: if isSignedIn();

      match /segments/{segmentId} {
        allow read: if isSignedIn();
        allow write: if false; // Запис лише через серверний API /api/translation/segment
      }
    }
    
    match /blogSettings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
